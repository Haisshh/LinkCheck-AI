# LinkCheck AI environment example
# Copy this file to .env for local development.
# Never commit real API keys, Discord webhooks, or admin tokens.

# Flask
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5000
SECRET_KEY=change-me

# Model/data paths
MODEL_PATH=model.pkl
DATA_PATH=data

# Threat intelligence
# Leave a value empty to skip that provider.
LINKCHECK_THREAT_INTEL=true
LINKCHECK_THREAT_INTEL_WAIT=2.5
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
IPQS_API_KEY=
URLHAUS_AUTH_KEY=
PHISHTANK_API_KEY=

# Feedback/admin
DISCORD_FEEDBACK_WEBHOOK=
FEEDBACK_ADMIN_TOKEN=
FEEDBACK_STORAGE_PATH=data/feedback.jsonl

# Logging
LOG_LEVEL=INFO
RATELIMIT_STORAGE_URI=
