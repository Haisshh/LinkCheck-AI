env/
ENV/

# Environment — NEVER commit this
.env
.env.*
!.env.example

# ML model files (large — regenerate with train.py)
model.pkl
model_tuned.pkl
features.pkl

# Data files (large)
data/scraped_data.csv
data/memoire_ia.csv
data/feedback.jsonl

# Screenshots (generated at runtime)
static/screenshots/

# Node — frontend dependencies only, NOT the build output
frontend/node_modules/
frontend/.vite/

# IMPORTANT: static/frontend/ is intentionally NOT ignored.
# The Vite build output must be committed so Render can serve it.
# Render's buildCommand runs `npm run build` which writes to static/frontend/,
# so even if you don't commit it locally, Render will generate it during build.
# But committing it avoids issues if the build step ever fails.

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log
logs/
